generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BachelorProjectType {
  MINOR
  MAJOR
}

enum Role {
  MAINTAINER
  COORDINATOR
  SUPERVISOR
  STUDENT
  EXTERNAL_EXAMINER
}

enum DegreeType {
  BACHELOR
  MASTER
}

enum GroupStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum ThesisStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum EvaluationStatus {
  DRAFT
  COMPLETED
}

enum EvaluationStage {
  PROPOSAL
  MID_TERM
  FINAL
}

enum EvaluationType {
  SUPERVISOR
  PROPOSAL_DEFENSE
  MIDTERM_DEFENSE
  FINAL_DEFENSE
  EXTERNAL_EXAMINER
}

model User {
  id          Int         @id @default(autoincrement())
  email       String      @unique
  password    String
  firstName   String
  lastName    String
  role        Role
  degreeType  DegreeType?
  departmentId Int?
  department  Department? @relation("UserDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  programId   Int?
  program     Program?    @relation("StudentProgram", fields: [programId], references: [id], onDelete: SetNull)
  rollNumber       String?
  resetToken       String?   @unique
  resetTokenExpires DateTime?
  active           Boolean   @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  coordinatorFor           Department?          @relation("CoordinatorDepartment")
  supervisedGroups         ProjectGroup[]        @relation("SupervisedGroups")
  supervisedTheses         Thesis[]              @relation("SupervisedTheses")
  thesis                   Thesis[]              @relation("StudentTheses")
  groupMembers             GroupMember[]
  evaluationsSubmitted     Evaluation[]          @relation("EvaluationSubmitter")
  componentsCreated        EvaluationComponent[] @relation("ComponentCreator")
  notifications            Notification[]
  proposals                Proposal[]
  recommendations          Recommendation[]
  examinerAssignments      ExaminerAssignment[]  @relation("ExternalExaminer")
  examinerAssignmentsAssigned ExaminerAssignment[] @relation("AssignedBy")
  auditLogs                   AuditLog[]

  @@index([role])
  @@index([departmentId])
  @@index([programId])
  @@index([active])
}

model Department {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  code          String   @unique
  coordinatorId Int?    @unique
  coordinator   User?    @relation("CoordinatorDepartment", fields: [coordinatorId], references: [id])
  createdAt     DateTime @default(now())

  programs       Program[]
  academicYears  AcademicYear[]
  users          User[]         @relation("UserDepartment")
}

model Program {
  id           Int      @id @default(autoincrement())
  name         String
  code         String   @unique
  departmentId Int
  department   Department  @relation(fields: [departmentId], references: [id])
  createdAt    DateTime    @default(now())

  students User[]        @relation("StudentProgram")
  groups   ProjectGroup[]
}

model AcademicYear {
  id           Int          @id @default(autoincrement())
  year         String
  semester     String
  departmentId Int
  department   Department   @relation(fields: [departmentId], references: [id])
  isActive     Boolean      @default(false)
  createdAt    DateTime     @default(now())

  groups ProjectGroup[]
  theses Thesis[]

  @@index([departmentId])
  @@index([isActive])
}

model ProjectGroup {
  id             Int                 @id @default(autoincrement())
  name           String
  projectTitle   String
  projectType    BachelorProjectType @default(MINOR)
  status         GroupStatus         @default(PENDING)
  supervisorId   Int?
  supervisor     User?               @relation("SupervisedGroups", fields: [supervisorId], references: [id])
  programId      Int?
  program        Program?            @relation(fields: [programId], references: [id])
  academicYearId Int
  academicYear   AcademicYear        @relation(fields: [academicYearId], references: [id])
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  members              GroupMember[]
  evaluations          Evaluation[]           @relation("GroupEvaluations")
  evaluationComponents EvaluationComponent[]  @relation("GroupComponents")
  proposals            Proposal[]
  recommendations      Recommendation[]
  examinerAssignments  ExaminerAssignment[]

  @@index([status])
  @@index([programId])
  @@index([academicYearId])
}

model GroupMember {
  id         Int          @id @default(autoincrement())
  studentId  Int
  student    User         @relation(fields: [studentId], references: [id])
  groupId    Int
  group      ProjectGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  rollNumber String
  createdAt  DateTime     @default(now())

  @@unique([studentId, groupId])
}

model Thesis {
  id             Int          @id @default(autoincrement())
  title          String
  projectType    String       @default("MASTER")
  studentId      Int
  student        User         @relation("StudentTheses", fields: [studentId], references: [id])
  status         ThesisStatus @default(PENDING)
  supervisorId   Int?
  supervisor     User?        @relation("SupervisedTheses", fields: [supervisorId], references: [id])
  academicYearId Int
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  evaluations          Evaluation[]          @relation("ThesisEvaluations")
  evaluationComponents EvaluationComponent[] @relation("ThesisComponents")
  proposals            Proposal[]
  recommendations      Recommendation[]
  examinerAssignments  ExaminerAssignment[]

  @@index([status])
  @@index([studentId])
  @@index([academicYearId])
}

model EvaluationComponent {
  id             Int            @id @default(autoincrement())
  name           String
  evaluationType EvaluationType
  evaluatorRole  Role
  maxMarks       Float
  groupId        Int?
  group          ProjectGroup?  @relation("GroupComponents", fields: [groupId], references: [id], onDelete: Cascade)
  thesisId       Int?
  thesis         Thesis?        @relation("ThesisComponents", fields: [thesisId], references: [id], onDelete: Cascade)
  createdById    Int
  createdBy      User           @relation("ComponentCreator", fields: [createdById], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  evaluations Evaluation[] @relation("ComponentEvaluations")

  @@index([groupId])
  @@index([thesisId])
}

model Evaluation {
  id             Int                @id @default(autoincrement())
  componentId    Int
  component      EvaluationComponent @relation("ComponentEvaluations", fields: [componentId], references: [id], onDelete: Cascade)
  stage          EvaluationStage
  evaluationType EvaluationType
  marks          Float?
  comment        String?
  status         EvaluationStatus   @default(DRAFT)
  submittedById  Int
  submittedBy    User               @relation("EvaluationSubmitter", fields: [submittedById], references: [id])
  groupId        Int?
  group          ProjectGroup?      @relation("GroupEvaluations", fields: [groupId], references: [id], onDelete: Cascade)
  thesisId       Int?
  thesis         Thesis?            @relation("ThesisEvaluations", fields: [thesisId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([componentId])
  @@index([groupId])
  @@index([thesisId])
}

model ExaminerAssignment {
  id                 Int           @id @default(autoincrement())
  externalExaminerId Int
  externalExaminer   User          @relation("ExternalExaminer", fields: [externalExaminerId], references: [id])
  groupId            Int?
  group              ProjectGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  thesisId           Int?
  thesis             Thesis?       @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  assignedById       Int
  assignedBy         User          @relation("AssignedBy", fields: [assignedById], references: [id])
  createdAt          DateTime      @default(now())

  @@unique([externalExaminerId, groupId])
  @@unique([externalExaminerId, thesisId])
}

model Proposal {
  id                Int           @id @default(autoincrement())
  stage             EvaluationStage
  documentUrl       String?
  supervisorComment String?
  studentFeedback   String?
  groupId           Int?
  group             ProjectGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  thesisId          Int?
  thesis            Thesis?       @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  submittedById     Int
  submittedBy       User          @relation(fields: [submittedById], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ExternalExaminer {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  phone      String?
  department String?
  createdAt  DateTime @default(now())
}

model Recommendation {
  id         Int           @id @default(autoincrement())
  content    String
  issuedById Int
  issuedBy   User          @relation(fields: [issuedById], references: [id])
  groupId    Int?
  group      ProjectGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  thesisId   Int?
  thesis     Thesis?       @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  action      String
  entity      String
  entityId    Int?
  details     String?
  performedById Int?
  performedBy User?    @relation(fields: [performedById], references: [id])
  createdAt   DateTime @default(now())

  @@index([entity])
  @@index([entityId])
  @@index([performedById])
  @@index([createdAt])
}
